datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

model Company {
  id           String        @id @default(cuid())
  name         String
  users        User[]
  clients      Client[]
  materials    Material[]
  catalogItems CatalogItem[]
  budgets      Budget[]
  createdAt    DateTime      @default(now())
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  role           Role
  company        Company  @relation(fields: [companyId], references: [id])
  companyId      String
  budgetsCreated Budget[] @relation("CreatedBy")
  createdAt      DateTime @default(now())
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String
  password  String
  company   Company  @relation(fields: [companyId], references: [id])
  companyId String
  budgets   Budget[]
  createdAt DateTime @default(now())

  @@unique([email, companyId])
}

model Material {
  id          String   @id @default(cuid())
  name        String
  description String?
  unit        String
  price       Float
  company     Company  @relation(fields: [companyId], references: [id])
  companyId   String
  createdAt   DateTime @default(now())
}

model CatalogItem {
  id                 String   @id @default(cuid())
  company            Company  @relation(fields: [companyId], references: [id])
  companyId          String
  sourceSheet        String
  sourceRow          Int
  sectionTitle       String?
  familyKey          String
  itemKey            String
  family             String
  subfamily          String?
  material           String?
  itemName           String
  comments           String?
  input1Label        String?
  input2Label        String?
  input3Label        String?
  measureUnit        String?
  quantityLabel      String?
  priceLabel         String?
  unitPriceBase      Float
  unitPriceRaw       Float?
  measureCurrent     Float?
  qtyCurrent         Float?
  realPriceCurrent   Float?
  companyCostCurrent Float?
  markupCurrent      Float?
  totalCurrent       Float?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([companyId, itemKey])
  @@index([companyId, family])
  @@index([companyId, familyKey])
}

model Budget {
  id          String          @id @default(cuid())
  reference   String
  status      BudgetStatus    @default(DRAFT)
  company     Company         @relation(fields: [companyId], references: [id])
  companyId   String
  client      Client          @relation(fields: [clientId], references: [id])
  clientId    String
  createdBy   User            @relation("CreatedBy", fields: [createdById], references: [id])
  createdById String
  versions    BudgetVersion[]
  createdAt   DateTime        @default(now())
}

model BudgetVersion {
  id        String   @id @default(cuid())
  version   Int
  data      Json
  sent      Boolean  @default(false)
  budget    Budget   @relation(fields: [budgetId], references: [id])
  budgetId  String
  createdAt DateTime @default(now())

  @@unique([budgetId, version])
}

enum Role {
  OWNER
  ADMIN
  WORKER
}

enum BudgetStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}
